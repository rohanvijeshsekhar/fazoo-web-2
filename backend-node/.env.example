# FAZO Backend — Environment Variables
# Copy this file to .env and fill in values before starting the server.
# On Hostinger: set these in Node.js App Manager → Environment Variables panel.

# ── Server ────────────────────────────
# Port the Express server listens on.
# Leave blank on Hostinger — the platform injects this automatically.
PORT=8000

# Set to 'production' on live server.
NODE_ENV=production

# ── Security ──────────────────────────
# Used for future signing/hashing if needed. Keep this secret.
# Generate a strong value with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=replace-this-with-a-strong-random-secret
